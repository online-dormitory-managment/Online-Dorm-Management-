PORT=5000

# MongoDB (required in production/Vercel)
# Use either MONGODB_URI or MONGO_URI
MONGODB_URI=mongodb+srv://<USER>:<PASS>@<CLUSTER>/<DB_NAME>?retryWrites=true&w=majority
#MONGO_URI=mongodb+srv://<USER>:<PASS>@<CLUSTER>/<DB_NAME>?retryWrites=true&w=majority

# Auth
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_64+_CHARS
JWT_EXPIRE=7d

# Email (optional; only if you use email sending)
EMAIL_USER=no-reply@yourdomain.com
EMAIL_PASS=your_smtp_or_app_password

# Chapa Payment Configuration (optional; only if payments enabled)
CHAPA_SECRET_KEY=CHASECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHAPA_WEBHOOK_SECRET=your_webhook_secret_here
CHAPA_RETURN_URL=http://localhost:5173/placement-request
CHAPA_CALLBACK_URL=http://localhost:5000/api/payment/verify
FRONTEND_URL=http://localhost:5173
